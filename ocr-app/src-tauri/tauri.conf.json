{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "PP-OCRv6",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "dialog": {
        "open": true
      },
      "protocol": {
        "asset": true,
        "assetScope": ["**"]
      },
      "window": {
        "all": true
      }
    },
    "bundle": {
      "identifier": "com.ppocr.ocr-app",
      "active": true,
      "targets": ["msi", "deb", "appimage"],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "models/**/*",
        "ort-lib/**/*"
      ]
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost blob: data:"
    },
    "windows": [
      {
        "title": "PP-OCRv6 - Offline OCR",
        "width": 1024,
        "height": 768,
        "minWidth": 640,
        "minHeight": 480
      }
    ]
  }
}
